# Application
SERVER_PORT=8084
SPRING_APPLICATION_NAME=notification-service

# PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/notification_db
SPRING_DATASOURCE_USERNAME=postgres
